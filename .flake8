[flake8]

# WPS305 Found `f` string
# WPS360 Found an unnecessary use of a raw string
# RST213 Inline emphasis start-string without end-string.
# RST210 Inline strong start-string without end-string.
# WPS226 Found string literal over-use: {0}
max-try-body-length = 3
max-module-members = 12
max-local-variables = 12
max-methods = 12
max-attributes = 12

per-file-ignores =
  test/unittest/__main__.py: F401
